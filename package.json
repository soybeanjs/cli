{
  "name": "@soybeanjs/cli",
  "version": "1.7.0-beta.2",
  "description": "SoybeanJS's command line tools",
  "homepage": "https://github.com/soybeanjs/cli",
  "bugs": {
    "url": "https://github.com/soybeanjs/cli/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Soybean",
    "email": "soybeanjs@outlook.com",
    "url": "https://github.com/soybeanjs"
  },
  "repository": {
    "url": "https://github.com/soybeanjs/cli.git"
  },
  "bin": {
    "soy": "./src/bin.js",
    "soybean": "./src/bin.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "publishConfig": {
    "bin": {
      "soybean": "dist/index.js",
      "soy": "dist/index.js"
    },
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "cleanup": "soy cleanup",
    "commit": "soy git-commit",
    "commit:zh": "soy git-commit -l=zh-cn",
    "lint": "oxlint --fix",
    "fmt": "oxfmt",
    "prepare": "simple-git-hooks",
    "publish-pkg": "pnpm -r publish --access public",
    "release": "soy release",
    "stub": "pnpm -r run stub",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "upkg": "soy ncu",
    "rei": "pnpm cleanup && pnpm i"
  },
  "dependencies": {
    "@soybeanjs/changelog": "^0.4.4",
    "bumpp": "^11.0.1",
    "c12": "^3.3.3",
    "cac": "^7.0.0",
    "consola": "^3.4.2",
    "enquirer": "^2.4.1",
    "execa": "^9.6.1",
    "kolorist": "^1.8.0",
    "npm-check-updates": "^19.6.5",
    "rimraf": "^6.1.3",
    "tinyglobby": "^0.2.15"
  },
  "devDependencies": {
    "@soybeanjs/cli": "link:",
    "@types/node": "^25.5.0",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.21.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm soy git-commit-verify",
    "pre-commit": "pnpm typecheck && pnpm lint-staged"
  },
  "lint-staged": {
    "*": "oxlint --fix && oxfmt"
  },
  "packageManager": "pnpm@10.32.1"
}
